generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums ─────────────────────────────────────────────────
enum Role {
  USER
  ADMIN
}

enum NotificationAudience {
  ALL
  SPECIFIC
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

// ── User ──────────────────────────────────────────────────
model User {
  id           String    @id @default(uuid())
  name         String    @db.VarChar(60)
  email        String    @unique @db.VarChar(255)
  password     String
  avatarUrl    String    @default("") @map("avatar_url")
  avatarPubId  String    @default("") @map("avatar_pub_id")
  role         Role      @default(USER)
  isActive     Boolean   @default(true) @map("is_active")
  refreshToken String?   @map("refresh_token")
  fcmToken     String    @default("") @map("fcm_token")
  lastLogin    DateTime? @map("last_login")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  // ← all 3 reverse relations must be here
  products      Product[]
  notifications Notification[] @relation("SentBy")
  blogs         Blog[]
}

// ── Product (also used for Projects) ─────────────────────
model Product {
  id          String   @id @default(uuid())
  title       String   @db.VarChar(120)
  description String   @db.VarChar(2000)
  price       Float    @default(0)
  category    String
  tags        String[] @default([])
  isPublished Boolean  @default(false) @map("is_published")
  isFeatured  Boolean  @default(false) @map("is_featured")
  views       Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  createdBy User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String         @map("user_id")
  images    ProductImage[]

  @@map("products")
}

model ProductImage {
  id        String  @id @default(uuid())
  url       String
  publicId  String  @map("public_id")
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String  @map("product_id")

  @@map("product_images")
}

// ── Notification ──────────────────────────────────────────
model Notification {
  id           String               @id @default(uuid())
  title        String               @db.VarChar(100)
  body         String               @db.VarChar(500)
  audience     NotificationAudience @default(ALL)
  recipientIds String[]             @default([]) @map("recipient_ids")
  data         Json                 @default("{}")
  status       NotificationStatus   @default(PENDING)
  sentAt       DateTime?            @map("sent_at")
  createdAt    DateTime             @default(now()) @map("created_at")

  sentBy   User   @relation("SentBy", fields: [sentById], references: [id])
  sentById String @map("sent_by_id")

  @@map("notifications")
}

// ── Site Content ──────────────────────────────────────────
model SiteContent {
  id        String   @id @default(uuid())
  section   String   @unique
  data      Json
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("site_content")
}

// ── Blog ─────────────────────────────────────────────────
model Blog {
  id          String   @id @default(cuid())
  title       String   @db.VarChar(200)
  slug        String   @unique @db.VarChar(220)
  excerpt     String?  @db.VarChar(500)
  body        String
  imageUrl    String   @default("") @map("image_url")
  imagePubId  String   @default("") @map("image_pub_id")
  tags        String[]
  isPublished Boolean  @default(false) @map("is_published")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  authorId    String   @map("author_id")
  author      User     @relation(fields: [authorId], references: [id])
}

// ── Contact Inquiry ───────────────────────────────────────
model ContactInquiry {
  id          String   @id @default(cuid())
  name        String   @db.VarChar(120)
  email       String   @db.VarChar(255)
  phone       String?  @db.VarChar(30)
  projectType String?  @map("project_type") @db.VarChar(80)
  budget      String?  @db.VarChar(40)
  brief       String
  isRead      Boolean  @default(false) @map("is_read")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("contact_inquiries")
}
